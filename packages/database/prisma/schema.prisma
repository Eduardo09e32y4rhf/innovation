generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  HR
  FINANCE
  ANALYST
  IA
  USER
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SYSTEM
}

model Company {
  id          String       @id @default(cuid())
  name        String
  cnpj        String?      @unique
  status      CompanyStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  jobs        Job[]
  candidates  Candidate[]
  subscriptions Subscription[]
  transactions Transaction[]
  payments    Payment[]
  auditLogs   AuditLog[]
}

model User {
  id            String   @id @default(cuid())
  companyId     String?
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(USER)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company? @relation(fields: [companyId], references: [id])
  auditLogs     AuditLog[]
}

model Job {
  id            String        @id @default(cuid())
  companyId     String?
  title         String
  description   String
  location      String?
  salaryRange   String?
  status        JobStatus     @default(OPEN)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company?      @relation(fields: [companyId], references: [id])
  candidates    Candidate[]
}

model Candidate {
  id              String          @id @default(cuid())
  companyId       String?
  jobId           String
  name            String
  email           String          @unique
  phone           String?
  resumeUrl       String?
  aiScore         Int?
  sentimentScore  Int?
  status          CandidateStatus @default(APPLIED)
  createdAt       DateTime        @default(now())
  company         Company?        @relation(fields: [companyId], references: [id])
  job             Job             @relation(fields: [jobId], references: [id])
}

model Plan {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  price       Decimal    @db.Decimal(10, 2)
  features    Json
  status      PlanStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                String             @id @default(cuid())
  companyId         String
  planId            String
  provider          String?
  providerId        String?            @unique
  status            SubscriptionStatus @default(TRIAL)
  currentPeriodEnd  DateTime?
  trialEndsAt       DateTime?
  startedAt         DateTime           @default(now())
  canceledAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company            @relation(fields: [companyId], references: [id])
  plan              Plan               @relation(fields: [planId], references: [id])
  payments          Payment[]
}

model Payment {
  id              String        @id @default(cuid())
  companyId       String
  subscriptionId  String?
  transactionId   String?       @unique
  provider        String?
  providerRef     String?       @unique
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("BRL")
  status          PaymentStatus @default(PENDING)
  dueAt           DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id])
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  transaction     Transaction?  @relation(fields: [transactionId], references: [id])
}

model Transaction {
  id            String          @id @default(cuid())
  companyId     String
  description   String
  amount        Decimal         @db.Decimal(10, 2)
  type          TransactionType
  category      String?
  occurredAt    DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  company       Company         @relation(fields: [companyId], references: [id])
  payment       Payment?
}

model AuditLog {
  id          String      @id @default(cuid())
  companyId   String?
  userId      String?
  action      AuditAction
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime    @default(now())
  company     Company?    @relation(fields: [companyId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])
}

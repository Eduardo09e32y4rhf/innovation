# Copie este arquivo para ".env" na raiz do repo na VPS e preencha.
# Nunca commite o .env real.

# Banco (interno ao Docker)
POSTGRES_USER=innovation_user
POSTGRES_PASSWORD=TROQUE_senha_forte_banco
POSTGRES_DB=innovation

# JWT — gere com: openssl rand -hex 32
JWT_SECRET=TROQUE_segredo_longo_e_aleatorio

# CORS — dominios que podem chamar a API (separados por virgula)
ALLOWED_ORIGINS=http://23.106.44.75:8080

# Acesso DEV (engenharia / dono da plataforma) — criado no seed
DEV_EMAIL=seu-email@dominio.com
DEV_PASSWORD=TROQUE_senha_dev_forte

# Senha do admin da empresa demo
ADMIN_PASSWORD=TROQUE_senha_admin

# Documentos usados pelo seed para upsert das empresas internas/demo
PLATFORM_COMPANY_DOCUMENT=00000000000000
DEMO_COMPANY_DOCUMENT=00000000000191

# URL publica da API (usada pelo frontend no build Docker)
NEXT_PUBLIC_API_URL=http://23.106.44.75:3333

# Copie este arquivo para ".env" na raiz do repo na VPS e preencha.
# Nunca commite o .env real.
#
# Regra da VPS:
# 1. Primeiro descubra quem usa as portas com:
#    ss -tulpn | grep -E ':3000|:3333|:5000|:3001|:5432|:5433|:8080|:8000'
#    docker ps --format "table {{.Names}}\t{{.Image}}\t{{.Ports}}\t{{.Status}}"
#    pm2 list
# 2. Se 3000/3333 forem do Innovation antigo, pare/recrie e mantenha 3000/3333.
# 3. So use 3001/5000 se 3000/3333 forem de outro sistema que nao pode parar.

# Banco interno ao Docker. Se 5432/5433 ja forem do banco correto do Innovation, voce pode usar o banco existente.
# Se subir Postgres Docker novo, exponha no host como 5435 para nao conflitar com Postgres nativo.
POSTGRES_USER=innovation_user
POSTGRES_PASSWORD=TROQUE_senha_forte_banco
POSTGRES_DB=innovation
POSTGRES_HOST_PORT=5435
REDIS_URL=redis://redis:6379

# Defaults da VPS atual: Nginx publica HTTPS e encaminha / para 8080 e /api para 3333.
API_PORT=3333
API_HOST_PORT=3333
WEB_PORT=3000
WEB_HOST_PORT=8080

# Alternativa apenas se 3000/3333 forem de outro projeto:
# API_PORT=5000
# API_HOST_PORT=5000
# WEB_PORT=3001
# WEB_HOST_PORT=3001

# JWT - gere com: openssl rand -hex 32
JWT_SECRET=TROQUE_segredo_longo_e_aleatorio

# CORS - dominio publico HTTPS servido pelo Nginx
ALLOWED_ORIGINS=https://vps8369.panel.icontainer.net

# Acesso DEV (engenharia / dono da plataforma) - criado no seed
DEV_EMAIL=seu-email@dominio.com
DEV_PASSWORD=TROQUE_senha_dev_forte

# Senha do admin da empresa demo
ADMIN_PASSWORD=TROQUE_senha_admin

# Documentos usados pelo seed para upsert das empresas internas/demo
PLATFORM_COMPANY_DOCUMENT=00000000000000
DEMO_COMPANY_DOCUMENT=00000000000191

# API embutida no build do frontend Docker. Em producao deve ser relativa para o Nginx.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_API_BASE=/api

# REDIS
REDIS_HOST_PORT=6379

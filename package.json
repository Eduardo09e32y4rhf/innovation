{
  "name": "innovation-ia-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Innovation.ia monorepo foundation",
  "packageManager": "npm@10.9.0",
  "scripts": {
    "debug:cwd": "node -e \"console.log('CWD:', process.cwd())\"",
    "dev": "npm run dev:web",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "dev:legacy": "npm --prefix legacy/FRONTEND run dev",
    "build": "npm run typecheck && npm run build:web",
    "build:api": "npm --prefix apps/api run build",
    "build:web": "npm --prefix apps/web run build",
    "build:desktop": "node -e \"const fs=require('fs'); if(!fs.existsSync('apps/desktop/package.json')){console.error('apps/desktop ainda não está implementado; próxima fase necessária é Fase Desktop.'); process.exit(1);} require('child_process').execSync('npm --prefix apps/desktop run build', {stdio:'inherit'});\"",
    "prepare:desktop": "npm run build:web && npm run build:desktop",
    "desktop:dist": "npm run prepare:desktop && npx electron-builder --dir",
    "build:installer": "npm run prepare:desktop && npx electron-builder --win nsis portable",
    "build:exe": "npm run build:installer",
    "start:web": "npm --prefix apps/web run start",
    "start:api": "npm --prefix apps/api run start",
    "vps:infra": "docker compose --env-file .env -f docker-compose.vps.yml up -d",
    "vps:infra:logs": "docker compose --env-file .env -f docker-compose.vps.yml logs -f",
    "vps:build": "npm --prefix apps/api run prisma:generate && npm run build:api && npm run build:web",
    "vps:migrate": "npm --prefix apps/api run prisma:deploy",
    "vps:start:api": "NODE_ENV=production npm --prefix apps/api run start",
    "vps:start:web": "NODE_ENV=production npm --prefix apps/web run start",
    "start:desktop": "npm --prefix apps/desktop run start",
    "workspace:bootstrap": "node scripts/workspace-bootstrap.cjs",
    "lint:root": "node scripts/workspace-lint.cjs",
    "lint": "npm run lint:root",
    "typecheck": "npm run typecheck:root",
    "typecheck:root": "tsc --noEmit -p tsconfig.json",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "db:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema packages/database/prisma/schema.prisma"
  },
  "author": "Innovation.ia Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-is-dev": "^2.0.0"
  },
  "build": {
    "appId": "com.innovation.ia",
    "productName": "Innovation IA",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "extraMetadata": {
      "main": "apps/desktop/dist/main.js"
    },
    "files": [
      "apps/desktop/package.json",
      "apps/desktop/dist/**/*",
      "apps/web/out/**/*",
      "MEDIA/**/*",
      "backend/**/*",
      "packages/**/*",
      "modules/**/*",
      "WHATSAPP/**/*",
      "legacy/IA/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false,
      "icon": "MEDIA/logo.ico",
      "artifactName": "Innovation-IA-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "Innovation IA"
    }
  },
  "workspaces": [
    "apps/web",
    "apps/desktop",
    "apps/api",
    "packages/*",
    "modules/*"
  ],
  "include-workspace-root": true
}

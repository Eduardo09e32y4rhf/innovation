# Innovation RH Connect - local environment template
# Copy this file to .env and fill with real values.
# Never commit the real .env file.

NODE_ENV=development
API_PORT=3333
PORT=3333
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL=postgresql://usuario:senha_forte@localhost:5432/innovation_rh_connect
POSTGRES_USER=innovation_rh_user
POSTGRES_PASSWORD=TROQUE_por_uma_senha_forte
POSTGRES_DB=innovation_rh_connect
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

JWT_SECRET=TROQUE_por_um_segredo_com_32_chars_ou_mais
JWT_EXPIRES_IN=7d
ENABLE_LOCAL_SESSION=true

NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=ws://localhost
NEXT_PUBLIC_CDN_URL=https://sua-cdn.cloudflare.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_LOCAL_SESSION=true

WHATSAPP_SESSION_PATH=./storage/whatsapp
WHATSAPPMEDIA_PATH=./storage/whatsapp-media

ASAAS_API_KEY=sua_chave_de_api_aqui
ASAAS_WEBHOOK_SECRET=seu_webhook_secret_aqui

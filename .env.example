# ════════════════════════════════════════════════════════════════════════
# Innovation.ia — Variáveis de Ambiente para PRODUÇÃO
# ════════════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha todos os valores com *.
# NUNCA comite o .env no git (já está no .gitignore).
#
# Para desenvolvimento local, veja .env.local.example
# ════════════════════════════════════════════════════════════════════════


# ── Banco de Dados ────────────────────────────────────────────────────────
# PILAR 2: PostgreSQL em vez de SQLite para produção
# Formato: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://innovation_user:SENHA_FORTE_AQUI@localhost:5432/innovation_db
# Para Docker Compose interno:
# DATABASE_URL=postgresql://innovation_user:SENHA_FORTE_AQUI@postgres:5432/innovation_db

# ── Segurança JWT ─────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GERE_UMA_CHAVE_SECRETA_FORTE_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── APIs de IA ────────────────────────────────────────────────────────────
# Gemini: Adicione múltiplas chaves separadas por vírgula (rotação automática)
GEMINI_API_KEYS=AIzaSy...,AIzaSy...
OPENAI_API_KEY=sk-proj-...
NVIDIA_API_KEY=nvapi-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Asaas (Pagamentos) ────────────────────────────────────────────────────
# PILAR 3: Configure para que o webhook ative planos automaticamente
#
# 1. Acesse: https://app.asaas.com/config/token
# 2. Copie o token de Produção (ou Sandbox para testes)
# 3. Registre o webhook: cd apps/backend && python setup_asaas_webhook.py
ASAAS_API_KEY=
ASAAS_API_URL=https://www.asaas.com/api/v3
# Para sandbox: ASAAS_API_URL=https://sandbox.asaas.com/api/v3

# Token secreto que o Asaas envia no header para verificação (você define)
ASAAS_WEBHOOK_TOKEN=GERE_UM_TOKEN_SECRETO_AQUI

# URL pública do seu backend onde o Asaas vai enviar os eventos de pagamento
# Deve ser HTTPS e acessível pela internet
# Exemplo: https://api.seudominio.com.br/api/payments/webhook
ASAAS_WEBHOOK_URL=https://SEU_DOMINIO.com.br/api/payments/webhook

# ── Mercado Pago (alternativo) ────────────────────────────────────────────
# MP_ACCESS_TOKEN=APP_USR-...

# ── CORS ──────────────────────────────────────────────────────────────────
# Domínio do Frontend em produção
ALLOWED_ORIGINS=https://seudominio.com.br,https://app.seudominio.com.br

# ── URLs ──────────────────────────────────────────────────────────────────
API_URL=https://api.seudominio.com.br
BASE_URL=https://api.seudominio.com.br
NEXT_PUBLIC_API_URL=https://api.seudominio.com.br

# ── Email (para recuperação de senha) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com.br
SMTP_PASSWORD=

# ── Observabilidade ───────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# SENTRY_DSN=https://...

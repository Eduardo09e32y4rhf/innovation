# =====================================================
# Innovation.ia - production/local environment template
# =====================================================
# Copy this file to .env and fill with real values.
# Never commit the real .env file.

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
DEBUG=false
PORT=8000
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Database / cache ------------------------------------------------------
DATABASE_URL=postgresql://innovation_user:innovation_pass@localhost:5432/innovation_ia
POSTGRES_USER=innovation_user
POSTGRES_PASSWORD=change_me_now
POSTGRES_DB=innovation_ia
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# --- Auth ------------------------------------------------------------------
SECRET_KEY=change_me_to_a_long_random_secret
JWT_SECRET=change_me_to_a_long_random_jwt_secret
JWT_REFRESH_SECRET=change_me_to_a_long_random_refresh_secret
JWT_EXPIRES_IN=7d

# --- AI providers ----------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEYS=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.7
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=4096
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# --- Payments --------------------------------------------------------------
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=change_me_to_a_webhook_token
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PREMIUM=price_your_premium_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id

# --- Email -----------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Innovation IA <no-reply@innovation.ia>

# --- Storage / media -------------------------------------------------------
WHATSAPP_SESSION_PATH=./whatsapp_sessions
WHATSAPPMEDIA_PATH=./whatsapp_media
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=innovation-ia-media
AWS_CLOUDFRONT_URL=https://cdn.innovation.ia

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key

# --- Observability / integrations -----------------------------------------
SENTRY_DSN=https://your_sentry_dsn
POSTHOG_API_KEY=your_posthog_api_key
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REFRESH_TOKEN=your_linkedin_refresh_token
WEB_APP_URL=http://localhost:3000
DESKTOP_PROD_URL=

# --- Optional service overrides -------------------------------------------
API_URL=http://localhost:8000
BASE_URL=http://localhost:8000

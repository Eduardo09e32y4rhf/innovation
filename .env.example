# Innovation RH Connect - local environment template
# Copy this file to .env and fill with real values.
# Never commit the real .env file.

NODE_ENV=development
API_PORT=3333
PORT=3333
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL=postgresql://usuario:senha_forte@localhost:5432/innovation_rh_connect
POSTGRES_USER=innovation_rh_user
POSTGRES_PASSWORD=TROQUE_por_uma_senha_forte
POSTGRES_DB=innovation_rh_connect
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

JWT_SECRET=TROQUE_por_um_segredo_com_32_chars_ou_mais
JWT_EXPIRES_IN=7d
ENABLE_LOCAL_SESSION=true

NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=ws://localhost
NEXT_PUBLIC_CDN_URL=https://sua-cdn.cloudflare.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_LOCAL_SESSION=true

WHATSAPP_SESSION_PATH=./storage/whatsapp
WHATSAPPMEDIA_PATH=./storage/whatsapp-media

ASAAS_API_KEY=sua_chave_de_api_aqui
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=token_seguro_com_no_minimo_32_caracteres
ASAAS_WEBHOOK_SECRET=token_legado_opcional

# Tipo de cobrança padrão gerado pelo Asaas (PIX | BOLETO | CREDIT_CARD | UNDEFINED)
# O Asaas usará este tipo quando nenhum for informado explicitamente.
ASAAS_DEFAULT_BILLING_TYPE=PIX

# ─── Notificações Financeiras ─────────────────────────────────────────────────
# O Asaas NÃO enviará SMS, WhatsApp ou ligações automáticas.
# Todas as comunicações financeiras são controladas pelo próprio Innovation RH.

# Habilitar notificações financeiras globalmente
FINANCE_NOTIFICATIONS_ENABLED=true

# Canal: notificações internas no painel
FINANCE_INTERNAL_NOTIFICATIONS_ENABLED=true

# Canal: e-mail (preparado, implementação futura)
FINANCE_EMAIL_NOTIFICATIONS_ENABLED=true

# Canal: WhatsApp do Innovation RH (desabilitado por padrão — requer consentimento da empresa)
FINANCE_WHATSAPP_NOTIFICATIONS_ENABLED=false

# Lembretes: quantos dias ANTES do vencimento enviar aviso
FINANCE_NOTIFICATION_REMINDER_DAYS_BEFORE=3

# Lembretes: quantos dias APÓS o vencimento enviar cobrança (separados por vírgula)
FINANCE_NOTIFICATION_OVERDUE_DAYS=1,5,10

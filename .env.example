# Innovation.ia — Enterprise OS Environment Variables Example
# Duplicate this file as .env and fill in the values

# --- Security ---
SECRET_KEY=innovation_v2_premium_dark_change_this_for_production
ALGORITHM=HS256
ALLOWED_ORIGINS=*

# --- Database ---
# For Local: sqlite:///./innovation_rh.db
# For Docker/Production: postgresql://user:password@localhost:5432/db
DATABASE_URL=sqlite:///./innovation_rh.db

# --- Redis (Required for Workers/Cache) ---
REDIS_URL=redis://localhost:6379/0

# --- AI Orchestration (Key Rotation) ---
# Gemini: Separate multiple keys with commas
GEMINI_API_KEYS=key1,key2,key3
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
NVIDIA_API_KEY=your_nvidia_key

# --- Payments ---
ASAAS_API_KEY=your_asaas_key
MP_ACCESS_TOKEN=your_mercadopago_token

# --- Infrastructure ---
API_URL=http://localhost:8000
BASE_URL=http://localhost:8000

# --- Optional Services ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=

# Innovation RH Connect - local environment template
# Copy this file to .env and fill with real values.
# Never commit the real .env file.

NODE_ENV=development
API_PORT=3333
PORT=3333
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL=postgresql://innovation_rh_user:innovation_rh_pass@localhost:5432/innovation_rh_connect
POSTGRES_USER=innovation_rh_user
POSTGRES_PASSWORD=change_me_now
POSTGRES_DB=innovation_rh_connect
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

JWT_SECRET=change_me_to_a_long_random_jwt_secret
JWT_EXPIRES_IN=7d
ENABLE_LOCAL_SESSION=true

NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_WS_URL=ws://localhost:3333
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_LOCAL_SESSION=true

WHATSAPP_SESSION_PATH=./storage/whatsapp
WHATSAPPMEDIA_PATH=./storage/whatsapp-media

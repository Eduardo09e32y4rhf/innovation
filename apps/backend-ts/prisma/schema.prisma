// Prisma schema for Innovation.ia Backend TS
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  hashed_password String
  role          String   @default("candidate")
  two_factor_enabled Boolean @default(false)
  encrypted_data Bytes?  // BlackBox
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Company {
  id Int @id @default(autoincrement())
  owner_user_id Int
  name String
  cnpj String @unique
  user User @relation(fields: [owner_user_id], references: [id])
}

model Job {
  id Int @id @default(autoincrement())
  company_id Int
  title String
  description String?
  created_at DateTime @default(now())
}


{
  "name": "innovation-rh-connect-api",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS API for Innovation RH Connect",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "seed:admin": "node prisma/seed-admin.cjs",
    "seed:mvp": "node prisma/seed-admin.cjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.19",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.19",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.19",
    "@nestjs/platform-socket.io": "^10.4.19",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.4.19",
    "@prisma/client": "^6.6.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.2.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.9",
    "@types/node": "^20.17.32",
    "@types/qrcode": "^1.5.5",
    "prisma": "^6.6.0",
    "typescript": "^5.8.3"
  }
}

{
  "name": "innovation-rh-connect-api",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS API for Innovation RH Connect",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc -p tsconfig.json || true",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:deploy": "npm run prisma:deploy",
    "db:seed": "npm run seed:mvp",
    "db:migrate-vps": "node prisma/migrate-vps-db.js",
    "seed:admin": "node prisma/seed-admin.cjs",
    "seed:mvp": "node prisma/seed-admin.cjs",
    "seed:realistic-demo": "npx tsx prisma/seed-realistic-demo.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/client": "^6.6.0",
    "@socket.io/redis-adapter": "8.3.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "5.11.1",
    "nodemailer": "9.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@types/node": "^20.17.32",
    "@types/nodemailer": "8.0.1",
    "@types/qrcode": "^1.5.5",
    "prisma": "^6.6.0",
    "typescript": "^5.8.3"
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DEV
  COMERCIAL
  ADMIN
  RH
  GESTOR
  FUNCIONARIO
  CONSULTA
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum WhatsappStatus {
  DISCONNECTED
  CONNECTING
  QR_CODE
  CONNECTED
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum CandidateStatus {
  NEW
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum FinancialTransactionType {
  REVENUE
  EXPENSE
}

enum FinancialTransactionStatus {
  PENDING
  PAID
  CANCELED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

model Company {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  legalName    String?
  document     String?  @unique
  logoUrl      String?  @db.Text
  phone        String?
  email        String?
  address      String?
  primaryColor String?
  theme        String?  @default("light")
  commercialOwnerId String? @db.Uuid
  subscriptionStartedAt DateTime @default(now())
  suspensionReason String?
  status       CompanyStatus @default(ACTIVE)
  maxUsers     Int      @default(6)
  maxEmployees Int      @default(50)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users         User[]
  commercialOwner User? @relation("CommercialOwner", fields: [commercialOwnerId], references: [id], onDelete: SetNull)
  employees     Employee[]
  whatsapp      WhatsappInstance[]
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  jobs          Job[]
  candidates    Candidate[]
  applications  Application[]
  transactions  FinancialTransaction[]
  privacyConsents PrivacyConsent[]
  auditLogs     AuditLog[]

  @@index([commercialOwnerId])
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @db.Uuid
  name         String
  email        String   @unique
  passwordHash String
  passwordChangedAt DateTime @default(now())
  forcePasswordChange Boolean @default(false)
  role         UserRole @default(FUNCIONARIO)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  commercialCompanies Company[]    @relation("CommercialOwner")
  employee        Employee?
  privacyConsents PrivacyConsent[]
  auditLogs       AuditLog[]

  @@index([companyId])
}


model Employee {
  id            String         @id @default(uuid()) @db.Uuid
  companyId     String         @db.Uuid
  userId        String?        @unique @db.Uuid
  name          String
  cpf           String         @unique
  email         String
  phone         String?
  birthDate     DateTime?
  registration  String?
  position      String
  department    String
  managerId     String?        @db.Uuid
  admissionDate DateTime
  terminationDate DateTime?
  status        EmployeeStatus @default(ACTIVE)
  salary        Decimal?       @db.Decimal(12, 2)
  contractType  String?
  cnpj          String?
  legalName     String?
  tradeName     String?
  unit          String?
  workScale     String?
  customWorkScale String?
  dailyWorkload String?
  standardEntry String?
  standardLunchStart String?
  standardLunchReturn String?
  standardExit  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  timeTracks TimeTrack[]
  vacations  Vacation[]

  @@index([companyId])
  @@index([cpf])
}

model TimeTrack {
  id            String    @id @default(uuid()) @db.Uuid
  employeeId    String    @db.Uuid
  date          DateTime  @db.Date
  entry         DateTime?
  lunchStart    DateTime?
  lunchReturn   DateTime?
  exit          DateTime?
  totalWorked   Int?
  dailyBalance  Int?
  observation   String?
  latitude      Float?
  longitude     Float?
  manualReason  String?
  manualStatus  String?   @default("approved")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
}

model Vacation {
  id                String         @id @default(uuid()) @db.Uuid
  employeeId        String         @db.Uuid
  acquisitionPeriod String
  startDate         DateTime
  endDate           DateTime
  daysUsed          Int
  status            VacationStatus @default(PENDING)
  observation       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model PrivacyConsent {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @db.Uuid
  userId      String    @db.Uuid
  termVersion String
  purpose     String
  ipAddress   String?
  userAgent   String?
  acceptedAt  DateTime  @default(now())
  revokedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, termVersion])
  @@index([companyId])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @db.Uuid
  userId    String?  @db.Uuid
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, entity])
  @@index([userId])
}

model WhatsappInstance {
  id        String         @id @default(uuid()) @db.Uuid
  companyId String         @db.Uuid
  sessionId String         @unique
  status    WhatsappStatus @default(DISCONNECTED)
  qrCode    String?
  phone     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}


model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @db.Uuid
  name      String?
  phone     String
  email     String?
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  candidates    Candidate[]

  @@unique([companyId, phone])
  @@index([companyId])
}


model Conversation {
  id            String             @id @default(uuid()) @db.Uuid
  companyId     String             @db.Uuid
  contactId     String             @db.Uuid
  whatsappJid   String
  status        ConversationStatus @default(OPEN)
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([companyId, whatsappJid])
  @@index([companyId])
  @@index([companyId, status])
}

model Message {
  id             String           @id @default(uuid()) @db.Uuid
  companyId      String           @db.Uuid
  conversationId String           @db.Uuid
  externalId     String?
  body           String
  direction      MessageDirection
  status         MessageStatus    @default(PENDING)
  sentAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([companyId, externalId])
  @@index([companyId])
  @@index([companyId, conversationId])
}

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String    @db.Uuid
  title          String
  description    String
  location       String?
  employmentType String?
  salaryRange    String?
  benefits       String[]  @default([])
  status         JobStatus @default(OPEN)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([companyId])
}


model Candidate {
  id            String          @id @default(uuid()) @db.Uuid
  companyId     String          @db.Uuid
  contactId     String?         @db.Uuid
  name          String
  email         String?
  phone         String?
  linkedinUrl   String?
  coverLetter   String?
  resumeUrl     String?
  aiScore       Int?
  aiSummary     String?
  aiNotes       String?
  aiSkills      String[]        @default([])
  lastSentiment String?
  status        CandidateStatus @default(NEW)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact      Contact?      @relation(fields: [contactId], references: [id])
  applications Application[]

  @@index([companyId])
  @@index([companyId, email])
}

model Application {
  id          String            @id @default(uuid()) @db.Uuid
  companyId   String            @db.Uuid
  candidateId String            @db.Uuid
  jobId       String            @db.Uuid
  status      ApplicationStatus @default(APPLIED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([companyId, candidateId, jobId])
  @@index([companyId])
}


model FinancialTransaction {
  id          String                     @id @default(uuid()) @db.Uuid
  companyId   String                     @db.Uuid
  description String
  amount      Decimal                    @db.Decimal(12, 2)
  type        FinancialTransactionType
  status      FinancialTransactionStatus @default(PENDING)
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, status])
}

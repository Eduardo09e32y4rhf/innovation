generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DEV
  COMERCIAL
  ADMIN
  RH
  GESTOR
  FUNCIONARIO
  CONSULTA
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum PlanType {
  FREE
  BASE
  PRO
  ENTERPRISE
}

enum BillingStatus {
  TRIAL
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WhatsappStatus {
  DISCONNECTED
  CONNECTING
  QR_CODE
  CONNECTED
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum CandidateStatus {
  NEW
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum FinancialTransactionType {
  REVENUE
  EXPENSE
}

enum FinancialTransactionStatus {
  PENDING
  PAID
  CANCELED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum NotificationType {
  SIMPLE_NOTICE
  RH_NOTICE
  VACATION_NOTICE
  WARNING_NOTICE
  SUSPENSION_NOTICE
  DOCUMENT_NOTICE
  SYSTEM_NOTICE
  PLATFORM_NOTICE
  URGENT_NOTICE
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
  PENDING_RESPONSE
  ACCEPTED
  REFUSED
  ACKNOWLEDGED
  REFUSED_ACKNOWLEDGMENT
  DRAFT
  SENT
  CANCELLED
  EXPIRED
}

enum NotificationTargetType {
  USER
  EMPLOYEE
  DEPARTMENT
  ROLE
  ALL
}

enum TimeRuleStatus {
  ACTIVE
  INACTIVE
}

enum TimeOccurrenceType {
  LATE_ARRIVAL
  EARLY_LEAVE
  ABSENCE
  JUSTIFIED_ABSENCE
  UNJUSTIFIED_ABSENCE
  MEDICAL_CERTIFICATE
  MANUAL_ADJUSTMENT
  MISSING_PUNCH
  OVERTIME
  NEGATIVE_BALANCE
  POSITIVE_BALANCE
  DAY_OFF
  DSR
  HOLIDAY
  VACATION
  LEAVE
  EXTERNAL_WORK
  HOME_OFFICE
  TRAINING
}

enum CommitmentType {
  DOCUMENT_DELIVERY
  DOCUMENT_SIGNATURE
  MEDICAL_EXAM
  RETURN_FROM_LEAVE
  MEETING_RH
  RENEWAL
  ADMIN_PENDING
  VACATION
  WARNING
  SUSPENSION
  TRAINING
  ONBOARDING
  OTHER
}

enum CommitmentStatus {
  PENDING
  TODAY
  OVERDUE
  UPCOMING
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum CommitmentPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AsoType {
  ADMISSIONAL
  PERIODICO
  RETORNO_AO_TRABALHO
  MUDANCA_DE_FUNCAO
  DEMISSIONAL
  COMPLEMENTAR
}

enum AsoStatus {
  PENDING
  SCHEDULED
  COMPLETED
  NEAR_EXPIRATION
  EXPIRED
  CANCELLED
  WAITING_DOCUMENT
  WAITING_ADDITIONAL_EXAM
}

enum AttachmentOwnerType {
  COMMITMENT
  ASO
  EMPLOYEE
  NOTIFICATION
}

enum ActivityEntityType {
  COMMITMENT
  ASO
  EMPLOYEE
  NOTIFICATION
}

model Company {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  slug      String? @unique
  legalName String?
  document  String? @unique
  logoUrl   String? @db.Text
  phone     String?
  email     String?
  address   String? // Mantido para migração

  // Dados Contratuais e Fiscais
  stateRegistration     String?
  municipalRegistration String?

  // Endereço Estruturado
  zipCode           String?
  street            String?
  streetNumber      String?
  addressComplement String?
  neighborhood      String?
  city              String?
  state             String?

  // Representante Legal
  legalRepresentativeName  String?
  legalRepresentativeCpf   String?
  legalRepresentativeRole  String?
  legalRepresentativeEmail String?
  legalRepresentativePhone String?

  latitude              Float?
  longitude             Float?
  radiusTolerance       Int?          @default(150)
  primaryColor          String?
  theme                 String?       @default("light")
  commercialOwnerId     String?       @db.Uuid
  subscriptionStartedAt DateTime      @default(now())
  suspensionReason      String?
  status                CompanyStatus @default(ACTIVE)

  // Camada Comercial (Tier 2)
  plan          PlanType      @default(FREE)
  billingStatus BillingStatus @default(TRIAL)
  trialEndsAt   DateTime?

  maxUsers        Int     @default(6)
  maxEmployees    Int     @default(50)
  isActive        Boolean @default(true)
  payrollStartDay Int     @default(1)

  activeModules       String[] @default(["employees", "time-track", "vacations", "management"])
  asaasCustomerId     String?
  asaasSubscriptionId String?
  internalNotes       String?  @db.Text
  platformPlanId      String?  @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  commercialOwner  User?                  @relation("CommercialOwner", fields: [commercialOwnerId], references: [id], onDelete: SetNull)
  employees        Employee[]
  whatsapp         WhatsappInstance[]
  contacts         Contact[]
  conversations    Conversation[]
  messages         Message[]
  jobs             Job[]
  candidates       Candidate[]
  applications     Application[]
  transactions     FinancialTransaction[]
  privacyConsents  PrivacyConsent[]
  auditLogs        AuditLog[]
  managementEvents ManagementEvent[]
  asoRecords       EmployeeAsoRecord[]
  asoClinicPresets AsoClinicPreset[]
  notifications    Notification[]

  workScheduleRules WorkScheduleRule[]
  faceEnrollments   FaceEnrollment[]
  timeOccurrences   TimeOccurrence[]
  commitments       Commitment[]
  attachments       Attachment[]
  activityHistories ActivityHistory[]
  overtimeBanks     OvertimeBank[]
  timeTracks        TimeTrack[]
  overtimeRule      OvertimeRule?
  holidays          Holiday[]
  timeClosings      TimeClosing[]
  platformPlan      PlatformPlan?            @relation(fields: [platformPlanId], references: [id])
  platformInvoices  PlatformInvoice[]
  platformContract  PlatformContract?
  proposals         Proposal[]
  financeConfig     CompanyFinanceConfig?
  financeNotifLogs  FinanceNotificationLog[]

  // Módulo Escala
  schedules          Schedule[]
  userSchedules      UserSchedule[]
  scheduleExceptions ScheduleException[]
  swapRequests       ScheduleSwapRequest[]

  @@index([commercialOwnerId])
}

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  companyId            String    @db.Uuid
  name                 String
  email                String    @unique
  passwordHash         String
  passwordChangedAt    DateTime  @default(now())
  forcePasswordChange  Boolean   @default(false)
  role                 UserRole  @default(FUNCIONARIO)
  isActive             Boolean   @default(true)
  failedLoginAttempts  Int       @default(0)
  previousPasswords    String[]  @default([])
  resetPasswordCode    String?
  resetPasswordExpires DateTime?
  lastActiveAt         DateTime?
  customPermissions    Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  commercialCompanies    Company[]               @relation("CommercialOwner")
  employee               Employee?
  privacyConsents        PrivacyConsent[]
  auditLogs              AuditLog[]
  notificationRecipients NotificationRecipient[]
  sentNotifications      Notification[]          @relation("SentNotifications")
  responsibleCommitments Commitment[]            @relation("ResponsibleCommitment")
  createdCommitments     Commitment[]            @relation("CommitmentCreatedBy")
  completedCommitments   Commitment[]            @relation("CommitmentCompletedBy")
  createdAsos            EmployeeAsoRecord[]     @relation("AsoCreatedBy")
  updatedAsos            EmployeeAsoRecord[]     @relation("AsoUpdatedBy")
  completedAsos          EmployeeAsoRecord[]     @relation("AsoCompletedBy")
  uploadedAttachments    Attachment[]
  activityHistories      ActivityHistory[]
  overtimeApprovals      TimeTrack[]             @relation("OvertimeApprovals")
  createdProposals       Proposal[]

  @@index([companyId])
}

model Employee {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @db.Uuid
  userId    String? @unique @db.Uuid

  name String

  cpf            String? @unique
  email          String?
  phone          String?
  secondaryPhone String?
  rg             String?
  rgIssuer       String?
  rgState        String?
  rgDate         String?

  pis         String?
  pisFirstJob Boolean? @default(false)

  gender        String?
  maritalStatus String?
  nationality   String?
  birthplace    String?
  education     String?
  motherName    String?
  fatherName    String?

  voterTitle   String?
  voterZone    String?
  voterSection String?
  voterState   String?

  reservist String?

  cnh         String?
  cnhCategory String?
  cnhExpiry   String?

  cep                 String?
  street              String?
  streetNumber        String?
  addressComplement   String?
  neighborhood        String?
  city                String?
  state               String?
  observations        String?        @db.Text
  birthDate           DateTime?
  registration        String?
  position            String
  department          String
  managerId           String?        @db.Uuid
  admissionDate       DateTime
  terminationDate     DateTime?
  status              EmployeeStatus @default(ACTIVE)
  salary              Decimal?       @db.Decimal(12, 2)
  contractType        String?
  cnpj                String?
  legalName           String?
  tradeName           String?
  unit                String?
  workScale           String?
  workScheduleRuleId  String?        @db.Uuid
  customWorkScale     String?
  dailyWorkload       String?
  standardEntry       String?
  standardLunchStart  String?
  standardLunchReturn String?
  standardExit        String?
  suspensionReason    String?
  allowExternalWork   Boolean        @default(false)

  bankCode        String?
  bankName        String?
  bankAgency      String?
  bankAccount     String?
  bankAccountType String?

  dependents Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                   User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  timeTracks             TimeTrack[]
  workScheduleRule       WorkScheduleRule?       @relation(fields: [workScheduleRuleId], references: [id], onDelete: SetNull)
  vacations              Vacation[]
  managementEvents       ManagementEvent[]
  asoRecords             EmployeeAsoRecord[]
  timeOccurrences        TimeOccurrence[]
  notificationRecipients NotificationRecipient[]

  commitments    Commitment[]
  overtimeBank   OvertimeBank?
  faceEnrollment FaceEnrollment?
  timeClosings   TimeClosing[]

  // Módulo Escala
  userSchedules      UserSchedule[]
  scheduleExceptions ScheduleException[]
  swapRequests       ScheduleSwapRequest[]

  @@index([companyId])
  @@index([cpf])
}

model TimeTrack {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @db.Uuid
  employeeId String   @db.Uuid
  date       DateTime @db.Date

  // Registros
  entry       DateTime?
  lunchStart  DateTime?
  lunchReturn DateTime?
  exit        DateTime?

  // Cálculos
  totalWorked            Int? // minutos
  dailyBalance           Int? // minutos (pode ser negativo)
  overtime50Minutes      Int     @default(0)
  overtime100Minutes     Int     @default(0)
  nightShiftMinutes      Int     @default(0)
  incidentType           String? // "atraso", "saida_antecipada"
  lateMinutes            Int     @default(0)
  earlyLeaveMinutes      Int     @default(0)
  toleranceMinutes       Int?
  absenceMinutes         Int?
  clockedInWithoutFacial Boolean @default(false)

  // Aprovação (NOVO)
  overtimeApprovalStatus   String    @default("PENDING") // PENDING, APPROVED, REJECTED
  overtimeExceedsLimit     Boolean   @default(false)
  overtimeApprovedAt       DateTime?
  overtimeApprovedByUserId String?   @db.Uuid

  // Handling: RH decide banco vs pagamento (NOVO)
  overtimeHandling       String @default("PAYMENT") // BANK, PAYMENT, SPLIT
  overtimeBankMinutes    Int    @default(0) // Quanto vai pro banco
  overtimePaymentMinutes Int    @default(0) // Quanto entra em folha

  // Ajuste manual
  manualReason    String?
  manualStatus    String? @default("approved") // "pending", "approved", "rejected"
  observation     String?
  latitude        Float?
  longitude       Float?
  locationAddress String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approvedByUser User?    @relation("OvertimeApprovals", fields: [overtimeApprovedByUserId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([companyId])
  @@index([overtimeApprovalStatus])
  @@index([date])
  @@index([companyId, date])
  @@index([companyId, employeeId, date])
}

model WorkScheduleRule {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @db.Uuid

  // Identificação
  name        String
  description String?

  // Horários padrão
  standardEntry String? // "08:00"
  standardExit  String? // "18:00"
  breakMinutes  Int     @default(60)
  dailyMinutes  Int     @default(480) // 8h padrão
  weeklyMinutes Int     @default(2400) // 40h padrão

  // Tolerâncias (NOVO)
  lateToleranceMinutes       Int @default(10)
  earlyLeaveToleranceMinutes Int @default(10)
  overtimeToleranceMinutes   Int @default(5)

  // Limites (NOVO)
  maxDailyOvertimeMinutes   Int @default(120) // CLT: 2h
  maxMonthlyOvertimeMinutes Int @default(2400) // 40h

  // Escala customizável (NOVO)
  workScale      String @default("5x2") // "5x2", "6x1", "12x36", etc
  restDaysOfWeek Int[]  @default([0, 6]) // 0=domingo, 6=sábado

  // Turno noturno (NOVO)
  nightShiftEnabled Boolean @default(false)
  nightStartTime    String  @default("22:00")
  nightEndTime      String  @default("05:00")
  nightShiftPercent Int     @default(20) // % de adicional

  // Hora extra
  normalOvertimePercent  Int @default(50) // 50%
  holidayOvertimePercent Int @default(100) // 100%

  // Fechamento
  closingStartDay            Int @default(1)
  closingEndDay              Int @default(31)
  adjustmentDeadlineDay      Int @default(5)
  managerApprovalDeadlineDay Int @default(10)

  status String @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([companyId])
  @@index([status])
}

model TimeOccurrence {
  id               String             @id @default(uuid()) @db.Uuid
  companyId        String             @db.Uuid
  employeeId       String             @db.Uuid
  timeTrackId      String?            @db.Uuid
  type             TimeOccurrenceType
  date             DateTime           @db.Date
  minutes          Int
  status           String             @default("PENDING")
  reason           String?
  observation      String?
  createdByUserId  String?            @db.Uuid
  approvedByUserId String?            @db.Uuid
  approvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@index([date])
  @@index([type])
}

model Vacation {
  id                String         @id @default(uuid()) @db.Uuid
  employeeId        String         @db.Uuid
  acquisitionPeriod String
  startDate         DateTime
  endDate           DateTime
  daysUsed          Int
  status            VacationStatus @default(PENDING)
  observation       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model ManagementEvent {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @db.Uuid
  title             String
  description       String?
  eventType         String
  startDateTime     DateTime
  endDateTime       DateTime?
  responsibleUserId String?   @db.Uuid
  employeeId        String?   @db.Uuid
  status            String    @default("PENDENTE")
  priority          String    @default("MEDIA")
  createdBy         String?   @db.Uuid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([employeeId])
  @@index([startDateTime])
  @@index([companyId, status])
  @@map("management_events")
}

model EmployeeAsoRecord {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @db.Uuid
  employeeId         String    @db.Uuid
  asoType            AsoType
  examDate           DateTime?
  dueDate            DateTime?
  status             AsoStatus @default(PENDING)
  clinicName         String?
  doctorName         String?
  documentNumber     String?
  observation        String?
  attachmentId       String?
  createdBy          String?   @db.Uuid
  updatedBy          String?   @db.Uuid
  completedBy        String?   @db.Uuid
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdByUser   User?    @relation("AsoCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser   User?    @relation("AsoUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  completedByUser User?    @relation("AsoCompletedBy", fields: [completedBy], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([employeeId])
  @@index([asoType])
  @@index([dueDate])
  @@map("employee_aso_records")
}

model AsoClinicPreset {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @db.Uuid
  name       String
  cep        String?
  address    String?
  city       String?
  state      String?
  phone      String?
  doctorName String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("aso_clinic_presets")
}

model Commitment {
  id                 String             @id @default(uuid()) @db.Uuid
  companyId          String             @db.Uuid
  employeeId         String?            @db.Uuid
  title              String
  description        String?
  type               CommitmentType
  status             CommitmentStatus   @default(PENDING)
  priority           CommitmentPriority @default(NORMAL)
  dueDate            DateTime
  dueTime            String?
  responsibleUserId  String?            @db.Uuid
  createdByUserId    String?            @db.Uuid
  completedByUserId  String?            @db.Uuid
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  responsibleUser User?     @relation("ResponsibleCommitment", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  createdByUser   User?     @relation("CommitmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  completedByUser User?     @relation("CommitmentCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([employeeId])
  @@index([dueDate])
  @@index([status])
  @@map("commitments")
}

model Attachment {
  id               String              @id @default(uuid()) @db.Uuid
  companyId        String              @db.Uuid
  ownerType        AttachmentOwnerType
  ownerId          String
  fileName         String
  fileType         String
  fileSize         Int
  fileUrl          String
  storageKey       String?
  uploadedByUserId String?             @db.Uuid
  createdAt        DateTime            @default(now())

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([ownerType, ownerId])
}

model ActivityHistory {
  id             String             @id @default(uuid()) @db.Uuid
  companyId      String             @db.Uuid
  entityType     ActivityEntityType
  entityId       String
  action         String
  previousStatus String?
  newStatus      String?
  reason         String?
  metadata       Json?
  userId         String?            @db.Uuid
  createdAt      DateTime           @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([userId])
}

model Notification {
  id                       String                 @id @default(uuid()) @db.Uuid
  companyId                String                 @db.Uuid
  type                     NotificationType
  title                    String
  message                  String                 @db.Text
  priority                 NotificationPriority   @default(NORMAL)
  source                   String?                @db.VarChar(50)
  targetUrl                String?
  createdBy                String?                @db.Uuid
  startsAt                 DateTime?
  expiresAt                DateTime?
  requiresReadConfirmation Boolean                @default(false)
  requiresAcceptance       Boolean                @default(false)
  allowsRefusal            Boolean                @default(false)
  pinned                   Boolean                @default(false)
  targetType               NotificationTargetType @default(ALL)
  targetId                 String?
  status                   NotificationStatus     @default(DRAFT)
  sentAt                   DateTime?
  attachmentsJson          Json?
  extraJson                Json?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser User?                   @relation("SentNotifications", fields: [createdBy], references: [id], onDelete: SetNull)
  recipients    NotificationRecipient[]

  @@index([companyId])
  @@index([type])
  @@index([priority])
  @@index([startsAt])
  @@index([expiresAt])
  @@map("notifications")
}

model NotificationRecipient {
  id             String             @id @default(uuid()) @db.Uuid
  notificationId String             @db.Uuid
  userId         String             @db.Uuid
  employeeId     String?            @db.Uuid
  status         NotificationStatus
  readAt         DateTime?
  archivedAt     DateTime?
  responseJson   Json?
  createdAt      DateTime           @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([status])
  @@map("notification_recipients")
}

model PrivacyConsent {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @db.Uuid
  userId      String    @db.Uuid
  termVersion String
  purpose     String
  ipAddress   String?
  userAgent   String?
  acceptedAt  DateTime  @default(now())
  revokedAt   DateTime?
  latitude    Float?
  longitude   Float?
  address     String?
  photoBase64 String?   @db.Text
  pdfBase64   String?   @db.Text

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, termVersion])
  @@index([companyId])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @db.Uuid
  userId    String?  @db.Uuid
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?

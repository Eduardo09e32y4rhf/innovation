// schema.prisma - RH & ATS Module

model Job {
  id              String   @id @default(cuid())
  title           String
  description     String
  location        String?
  salaryRange     String?
  status          JobStatus @default(OPEN)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  candidates      Candidate[]
}

model Candidate {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String?
  resumeUrl       String?
  aiScore         Int?
  sentimentScore  Int?
  status          CandidateStatus @default(APPLIED)
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id])
  createdAt       DateTime @default(now())
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}
